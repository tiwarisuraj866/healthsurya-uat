# ── RAZORPAY PAYMENTS ─────────────────────────────────────────────────────────
# From: Razorpay Dashboard → Settings → API Keys
# Use TEST keys for development, LIVE keys for production
RAZORPAY_KEY_ID=rzp_live_...
RAZORPAY_KEY_SECRET=...YOUR_RAZORPAY_SECRET...

# From: Razorpay Dashboard → Webhooks → Add New Webhook → Secret
RAZORPAY_WEBHOOK_SECRET=...YOUR_WEBHOOK_SECRET...

# ── META WHATSAPP (Cloud API) ─────────────────────────────────────────────────
# From: developers.facebook.com → App → WhatsApp → Getting Started
META_WHATSAPP_PHONE_NUMBER_ID=...YOUR_PHONE_NUMBER_ID...
META_WHATSAPP_ACCESS_TOKEN=EAA...YOUR_PERMANENT_TOKEN...
META_WHATSAPP_VERIFY_TOKEN=...YOUR_CHOSEN_VERIFY_TOKEN...

# From: Meta App Dashboard → Settings → Basic → App Secret
META_APP_SECRET=...YOUR_META_APP_SECRET...

# ── SENTRY MONITORING ─────────────────────────────────────────────────────────
# From: sentry.io → Project → Settings → Client Keys (DSN)
NEXT_PUBLIC_SENTRY_DSN=https://...@...ingest.sentry.io/...

# From: sentry.io → Settings → Auth Tokens (for source map upload during build)
SENTRY_AUTH_TOKEN=sntrys_...

# ── POSTHOG ANALYTICS ─────────────────────────────────────────────────────────
# From: app.posthog.com → Project → Settings → Project API Key
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ── INTERNAL ──────────────────────────────────────────────────────────────────
# Random secret for server-to-server API calls (generate with: openssl rand -hex 32)
INTERNAL_API_SECRET=...GENERATE_WITH_OPENSSL_RAND_HEX_32...

# Set to "true" to show preview/demo data on public listing pages
NEXT_PUBLIC_PREVIEW_LISTINGS=false